{
  "name": "pandora-server",
  "version": "2.1.0",
  "description": "Servidor REST da aplicação PANDORA",
  "main": "init.js",
  "scripts": {
    "serve": "rm -rf ./build && webpack --colors --config compose/local/webpack.config.js  --bail",
    "start": "cross-env node ./out/init.js",
    "compile": "node ./node_modules/typescript/bin/tsc",
    "test": "cross-env TS_NODE_COMPILER_OPTIONS=\"{\\\"lib\\\": [\\\"ES2015\\\"]}\" NODE_ENV=test mocha --require ts-node/register ./src/test/*.spec.ts",
    "compiletests": "node ./node_modules/typescript/bin/tsc -p ./tests"
  },
  "keywords": [
    "server",
    "webservice",
    "node",
    "siap",
    "pandora"
  ],
  "author": "Augusto Almeida",
  "dependencies": {
