    "body-parser": "^1.19.0",
    "connect-redis": "^5.0.0",
    "crypto-js": "^4.0.0",
    "es6-crawler-detect": "^3.0.0",
    "express": "^4.17.1",
    "express-session": "^1.16.2",
    "got": "^11.0.2",
    "helmet": "^4.1.0",
    "ioredis": "^4.11.2",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.24.0",
    "morgan": "^1.8.1",
    "mssql": "^6.0.0",
    "multer": "^1.4.2",
    "natural": "^2.1.5",
    "nodemailer": "^6.3.0",
