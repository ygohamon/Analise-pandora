{
  "name": "pandora-app",
  "version": "2.0.0",
  "scripts": {
    "postinstall": "rimraf ./node_modules/cytoscape-node-html-label/dist/cytoscape-node-html-label.d.ts",
    "ng": "ng",
    "config": "ts-node -O '{\"module\": \"commonjs\"}' ./scripts/gera-env.ts",
    "start": "ng serve",
    "build": "ng build",
    "build:env": "npm run config -- --environment=dev && npm run config -- --environment=prod",
    "build:dev": "npm run config -- --environment=dev && ng build",
    "build:prod": "npm run config -- --environment=prod && ng build --prod",
    "build:stats": "npm run config -- --environment=prod && ng build --prod --stats-json",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "report": "webpack-bundle-analyzer dist/pandora-app/stats.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~9.1.7",
    "@angular/cdk": "^9.2.3",
    "@angular/common": "~9.1.7",
    "@angular/compiler": "~9.1.7",
    "@angular/core": "~9.1.7",
    "@angular/forms": "~9.1.7",
    "@angular/platform-browser": "~9.1.7",
    "@angular/platform-browser-dynamic": "~9.1.7",
    "@angular/router": "~9.1.7",
    "@angular/service-worker": "~9.1.7",
    "@asymmetrik/ngx-leaflet": "^7.0.0",
    "@auth0/angular-jwt": "~4.1.2",
    "@ngx-loading-bar/core": "^4.2.0",
    "@ngx-loading-bar/http-client": "^4.2.0",
    "@ngx-loading-bar/router": "^4.2.0",
    "chart.js": "^2.7.3",
    "crypto-js": "^3.1.9-1",
    "cytoscape": "^3.2.20",
    "cytoscape-cola": "^2.2.4",
    "cytoscape-cxtmenu": "^3.0.2",
    "cytoscape-node-html-label": "^1.1.3",
    "dayjs": "^1.8.16",
    "docx": "~5.3.0",
    "echarts": "^5.0.2",
    "file-saver": "^2.0.2",
    "font-awesome": "^4.7.0",
    "jspdf": "^1.5.3",
    "jspdf-autotable": "^3.2.10",
    "leaflet": "^1.3.4",
    "lodash-es": "^4.17.15",
    "ng-recaptcha": "^5.0.0",
    "ng2-file-upload": "^1.3.0",
    "ngx-device-detector": "^2.0.0",
    "ngx-echarts": "^5.2.2",
    "pdfmake": "^0.1.54",
    "plotly.js-cartesian-dist": "^1.51.0",
    "plotly.js-dist": "^1.51.0",
    "primeflex": "^2.0.0",
    "primeicons": "^4.0.0",
    "primeng": "^9.0.6",
    "quill": "^1.3.7",
    "rxjs": "~6.5.5",
    "xlsx": "^0.16.1",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.901.6",
    "@angular/cli": "~9.1.6",
    "@angular/compiler-cli": "~9.1.7",
    "@angular/language-service": "~9.1.7",
    "@types/googlemaps": "^3.38.0",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/leaflet": "^1.5.5",
    "@types/node": "^12.11.1",
    "codelyzer": "^5.1.2",
    "dotenv": "^6.1.0",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
