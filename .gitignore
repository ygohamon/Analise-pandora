# See http://help.github.com/ignore-files/ for more about ignoring files.

*.env
*.sql
!pandora-server/scripts/*.sql
*.pyc
*.log

# pandora-app
pandora-app/src/environments/environment.prod.ts
pandora-app/src/environments/environment.ts
pandora-app/src/environments/
pandora-app/dist
pandora-app/node_modules

# pandora-server
pandora-server/node_modules/
pandora-server/out/
pandora-server/build/
pandora-server/tmp/
pandora-server/heapdump/
pandora-server/.envs/models/*.json
!pandora-server/.envs/models/model.core.json

# pandora-crawlers
pandora-crawlers/node_modules/
pandora-crawlers/out/
pandora-crawlers/build/
pandora-crawlers/tmp/
pandora-crawlers/heapdump/
pandora-crawlers/.envs/models/*.json
!pandora-crawlers/.envs/models/model.core.json

# pandora-nginx
!nginx.env

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db
pandora-server/server.log
/pandora-app/.angular
